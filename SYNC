-- // Toggle row helper (h=34 each, gaps of 6px)
-- SYNC:   y=86,  ends 120
-- FREEZE: y=126, ends 160
-- PACKET: y=166, ends 200
local function makeToggleRow(parent, yPos, labelText)
    local Row = Instance.new("Frame")
    Row.Size = UDim2.new(1, -28, 0, 34)
    Row.Position = UDim2.new(0, 14, 0, yPos)
    Row.BackgroundColor3 = Color3.fromRGB(15, 22, 17)
    Row.BackgroundTransparency = 0.05
    Row.BorderSizePixel = 0
    Row.ZIndex = 2
    Row.Parent = parent

    local RowCorner = Instance.new("UICorner")
    RowCorner.CornerRadius = UDim.new(0, 10)
    RowCorner.Parent = Row

    local RowStroke = Instance.new("UIStroke")
    RowStroke.Color = Color3.fromRGB(57, 255, 20)
    RowStroke.Thickness = 1
    RowStroke.Transparency = 0.75
    RowStroke.Parent = Row

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -65, 1, 0)
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = labelText
    Label.TextColor3 = Color3.fromRGB(209, 250, 229)
    Label.TextSize = 10
    Label.Font = Enum.Font.GothamBold
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.ZIndex = 3
    Label.Parent = Row

    local isOn = false

    -- // Pill toggle (w=40, h=20)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0, 40, 0, 20)
    Btn.Position = UDim2.new(1, -48, 0.5, -10)
    Btn.BackgroundColor3 = Color3.fromRGB(20, 28, 22)
    Btn.BorderSizePixel = 0
    Btn.Text = ""
    Btn.AutoButtonColor = false
    Btn.ZIndex = 3
    Btn.Parent = Row

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(1, 0)
    BtnCorner.Parent = Btn

    local BtnStroke = Instance.new("UIStroke")
    BtnStroke.Color = Color3.fromRGB(57, 255, 20)
    BtnStroke.Thickness = 1
    BtnStroke.Transparency = 0.55
    BtnStroke.Parent = Btn

    -- // Knob (w=14, h=14)
    local Knob = Instance.new("Frame")
    Knob.Size = UDim2.new(0, 14, 0, 14)
    Knob.Position = UDim2.new(0, 3, 0.5, -7)
    Knob.BackgroundColor3 = Color3.fromRGB(57, 255, 20)
    Knob.BackgroundTransparency = 0.5
    Knob.BorderSizePixel = 0
    Knob.ZIndex = 5
    Knob.Parent = Btn

    local KnobCorner = Instance.new("UICorner")
    KnobCorner.CornerRadius = UDim.new(1, 0)
    KnobCorner.Parent = Knob

    -- // ON/OFF centered inside pill
    local State = Instance.new("TextLabel")
    State.Size = UDim2.new(1, 0, 1, 0)
    State.BackgroundTransparency = 1
    State.Text = "OFF"
    State.TextColor3 = Color3.fromRGB(57, 255, 20)
    State.TextSize = 7
    State.Font = Enum.Font.GothamBold
    State.TextXAlignment = Enum.TextXAlignment.Center
    State.TextYAlignment = Enum.TextYAlignment.Center
    State.TextTransparency = 0.45
    State.ZIndex = 4
    State.Parent = Btn

    Btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        if isOn then
            TweenService:Create(Knob, TweenInfo.new(0.22, Enum.EasingStyle.Quart), {
                Position = UDim2.new(0, 23, 0.5, -7),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BackgroundTransparency = 0
            }):Play()
            TweenService:Create(Btn, TweenInfo.new(0.22), { BackgroundColor3 = Color3.fromRGB(22, 101, 52) }):Play()
            TweenService:Create(Row, TweenInfo.new(0.22), { BackgroundColor3 = Color3.fromRGB(18, 30, 20) }):Play()
            RowStroke.Transparency = 0.35
            State.Text = "ON"
            State.TextTransparency = 0
        else
            TweenService:Create(Knob, TweenInfo.new(0.22, Enum.EasingStyle.Quart), {
                Position = UDim2.new(0, 3, 0.5, -7),
                BackgroundColor3 = Color3.fromRGB(57, 255, 20),
                BackgroundTransparency = 0.5
            }):Play()
            TweenService:Create(Btn, TweenInfo.new(0.22), { BackgroundColor3 = Color3.fromRGB(20, 28, 22) }):Play()
            TweenService:Create(Row, TweenInfo.new(0.22), { BackgroundColor3 = Color3.fromRGB(15, 22, 17) }):Play()
            RowStroke.Transparency = 0.75
            State.Text = "OFF"
            State.TextTransparency = 0.45
        end
    end)
end

